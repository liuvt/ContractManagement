@page "/admin/driver-accounts/{UserId}"
@attribute [Authorize(Roles = "Admin")]

@inject IDriverAccountService DriverAccountService
@inject ICompanyProfileService CompanyProfileService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Chi tiết tài khoản tài xế</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_detail is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
        Không tìm thấy tài khoản tài xế.
    </MudAlert>
}
else
{
    <PageHeader Title="@_detail.FullName" Subtitle="@GetSubtitle()">
        <MudButton Variant="Variant.Outlined"
                   StartIcon="@Icons.Material.Filled.ArrowBack"
                   OnClick="GoBack">
            Quay lại
        </MudButton>
    </PageHeader>

    <MudGrid>
        <MudItem xs="12" md="6">
            <DetailDriverUser Detail="@_detail" OnChanged="ReloadAsync" />
        </MudItem>

        <MudItem xs="12" md="6">
            <DetailDriverCompany Detail="@_detail"
                                 Companies="@_companies"
                                 SelectedCompanyId="@_selectedCompanyId"
                                 SelectedCompanyIdChanged="OnSelectedCompanyChanged"
                                 OnChanged="ReloadAsync" />
        </MudItem>

        <MudItem xs="12">
            <DetailDriverProfile Detail="@_detail"
                                 SelectedCompanyId="@_selectedCompanyId"
                                 OnChanged="ReloadAsync" />
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter]
    public string UserId { get; set; } = string.Empty;

    private bool _loading = true;
    private DriverAccountDetailDto? _detail;
    private IReadOnlyList<CompanyProfileOptionDto> _companies = Array.Empty<CompanyProfileOptionDto>();
    private Guid _selectedCompanyId;

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        if (string.IsNullOrWhiteSpace(UserId))
        {
            _detail = null;
            _loading = false;
            return;
        }

        try
        {
            _loading = true;

            var detailTask = DriverAccountService.GetDetailAsync(UserId);
            var companiesTask = CompanyProfileService.GetActiveOptionsAsync();

            await Task.WhenAll(detailTask, companiesTask);

            _detail = await detailTask;
            _companies = await companiesTask;

            InitializeSelectedCompany();
        }
        catch (Exception ex)
        {
            _detail = null;
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ReloadAsync()
    {
        await LoadAsync();
    }

    private void InitializeSelectedCompany()
    {
        if (_detail?.Profile is not null &&
            _detail.Profile.CompanyProfileId != Guid.Empty)
        {
            _selectedCompanyId = _detail.Profile.CompanyProfileId;
            return;
        }

        var company = _companies.FirstOrDefault(x => x.IsDefault)
                      ?? _companies.FirstOrDefault();

        _selectedCompanyId = company?.Id ?? Guid.Empty;
    }

    private Task OnSelectedCompanyChanged(Guid companyId)
    {
        _selectedCompanyId = companyId;
        return Task.CompletedTask;
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/admin/driver-accounts");
    }

    private string GetSubtitle()
    {
        if (_detail is null)
            return string.Empty;

        return string.IsNullOrWhiteSpace(_detail.EmployeeCode)
            ? _detail.UserName
            : $"{_detail.EmployeeCode} - {_detail.UserName}";
    }
}
