@page "/admin/company-profiles"
@attribute [Authorize(Roles = "Admin")]

@inject ICompanyProfileService CompanyProfileService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ISnackbar Snackbar

<PageTitle>Quản lý công ty</PageTitle>

<PageHeader Title="Quản lý công ty"
            Subtitle="Quản lý hồ sơ doanh nghiệp và công ty trực thuộc">

    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               OnClick="OpenCreate">
        Tạo công ty
    </MudButton>

</PageHeader>

<MudPaper Outlined="true"
          Class="pa-4 mb-4">

    <MudGrid>
        <MudItem xs="12" md="8">
            <MudTextField T="string"
                          @bind-Value="_keyword"
                          Label="Tìm kiếm"
                          Placeholder="Tên công ty, mã số thuế, đại diện..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true"
                          Clearable="true"
                          Variant="Variant.Outlined"
                          FullWidth="true" />
        </MudItem>

        <MudItem xs="12" md="4">
            <MudSelect T="bool?"
                       @bind-Value="_activeFilter"
                       Label="Trạng thái"
                       Variant="Variant.Outlined"
                       Clearable="true"
                       FullWidth="true">

                <MudSelectItem T="bool?"
                               Value="@((bool?)true)">
                    Đang hoạt động
                </MudSelectItem>

                <MudSelectItem T="bool?"
                               Value="@((bool?)false)">
                    Ngừng hoạt động
                </MudSelectItem>

            </MudSelect>
        </MudItem>
    </MudGrid>

</MudPaper>

@if (_creating)
{
    <MudPaper Outlined="true"
              Class="pa-4 mb-4">

        <MudStack Row="true"
                  Justify="Justify.SpaceBetween"
                  AlignItems="AlignItems.Center"
                  Class="mb-4">

            <MudText Typo="Typo.h6">
                Tạo hồ sơ doanh nghiệp
            </MudText>

            <MudIconButton Icon="@Icons.Material.Filled.Close"
                           Disabled="@_saving"
                           OnClick="CloseCreate" />
        </MudStack>

        <MudDivider Class="mb-4" />

        <MudForm @ref="_createForm">
            <MudGrid>
                <MudItem xs="12">
                    <MudTextField T="string"
                                  Label="Tên doanh nghiệp"
                                  @bind-Value="_createModel.CompanyName"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  RequiredError="Vui lòng nhập tên doanh nghiệp."
                                  FullWidth="true" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudTextField T="string"
                                  Label="Mã số thuế"
                                  @bind-Value="_createModel.TaxCode"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  RequiredError="Vui lòng nhập mã số thuế."
                                  FullWidth="true" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudTextField T="string"
                                  Label="Số giấy phép kinh doanh"
                                  @bind-Value="_createModel.BusinessLicenseNumber"
                                  Variant="Variant.Outlined"
                                  FullWidth="true" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField T="string"
                                  Label="Địa chỉ"
                                  @bind-Value="_createModel.Address"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  RequiredError="Vui lòng nhập địa chỉ."
                                  Lines="2"
                                  FullWidth="true" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudTextField T="string"
                                  Label="Số điện thoại"
                                  @bind-Value="_createModel.PhoneNumber"
                                  Variant="Variant.Outlined"
                                  FullWidth="true" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudTextField T="string"
                                  Label="Email"
                                  @bind-Value="_createModel.Email"
                                  Variant="Variant.Outlined"
                                  InputType="InputType.Email"
                                  FullWidth="true" />
                </MudItem>

                <MudItem xs="12">
                    <MudDivider Class="my-2" />
                    <MudText Typo="Typo.subtitle1">
                        Người đại diện
                    </MudText>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudTextField T="string"
                                  Label="Họ tên người đại diện"
                                  @bind-Value="_createModel.RepresentativeName"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  RequiredError="Vui lòng nhập người đại diện."
                                  FullWidth="true" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudTextField T="string"
                                  Label="Chức vụ"
                                  @bind-Value="_createModel.RepresentativePosition"
                                  Variant="Variant.Outlined"
                                  FullWidth="true" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudTextField T="string"
                                  Label="Số CCCD người đại diện"
                                  @bind-Value="_createModel.RepresentativeCitizenId"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  RequiredError="Vui lòng nhập số CCCD."
                                  FullWidth="true" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudDatePicker Label="Ngày cấp CCCD"
                                   @bind-Date="_createModel.RepresentativeCitizenIdIssuedDate"
                                   DateFormat="dd/MM/yyyy"
                                   Variant="Variant.Outlined"
                                   Clearable="true"
                                   Style="width:100%;" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField T="string"
                                  Label="Nơi cấp CCCD"
                                  @bind-Value="_createModel.RepresentativeCitizenIdIssuedPlace"
                                  Variant="Variant.Outlined"
                                  FullWidth="true" />
                </MudItem>

                <MudItem xs="12">
                    <MudDivider Class="my-2" />
                    <MudText Typo="Typo.subtitle1">
                        Thông tin thanh toán
                    </MudText>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudTextField T="string"
                                  Label="Số tài khoản ngân hàng"
                                  @bind-Value="_createModel.BankAccountNumber"
                                  Variant="Variant.Outlined"
                                  FullWidth="true" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudTextField T="string"
                                  Label="Ngân hàng"
                                  @bind-Value="_createModel.BankName"
                                  Variant="Variant.Outlined"
                                  FullWidth="true" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudSwitch T="bool"
                               @bind-Value="_createModel.IsActive"
                               Color="Color.Success"
                               Label="Đang hoạt động" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudSwitch T="bool"
                               @bind-Value="_createModel.IsDefault"
                               Color="Color.Primary"
                               Label="Công ty mặc định" />
                </MudItem>
            </MudGrid>

            <MudStack Row="true"
                      Justify="Justify.FlexEnd"
                      Spacing="2"
                      Class="mt-5">

                <MudButton Variant="Variant.Outlined"
                           Disabled="@_saving"
                           OnClick="CloseCreate">
                    Hủy
                </MudButton>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Disabled="@_saving"
                           StartIcon="@Icons.Material.Filled.Save"
                           OnClick="CreateAsync">

                    @(_saving ? "Đang lưu..." : "Tạo công ty")

                </MudButton>
            </MudStack>
        </MudForm>

    </MudPaper>
}

@if (_loading)
{
    <MudProgressLinear Indeterminate="true"
                       Color="Color.Primary" />
}
else
{
    <MudTable T="CompanyProfileListItemDto"
              Items="@FilteredItems"
              Hover="true"
              Striped="true"
              Breakpoint="Breakpoint.Sm"
              Elevation="1"
              RowsPerPage="10">

        <HeaderContent>
            <MudTh>Tên doanh nghiệp</MudTh>
            <MudTh>Mã số thuế</MudTh>
            <MudTh>Người đại diện</MudTh>
            <MudTh>Liên hệ</MudTh>
            <MudTh>Tài xế</MudTh>
            <MudTh>Trạng thái</MudTh>
            <MudTh></MudTh>
        </HeaderContent>

        <RowTemplate>
            <MudTd DataLabel="Tên doanh nghiệp">
                <MudText Typo="Typo.subtitle2">
                    @context.CompanyName
                </MudText>

                @if (context.IsDefault)
                {
                    <MudChip T="string"
                             Size="Size.Small"
                             Color="Color.Primary"
                             Class="mt-1">
                        Mặc định
                    </MudChip>
                }
            </MudTd>

            <MudTd DataLabel="Mã số thuế">
                @context.TaxCode
            </MudTd>

            <MudTd DataLabel="Người đại diện">
                @context.RepresentativeName
            </MudTd>

            <MudTd DataLabel="Liên hệ">
                <MudText Typo="Typo.body2">
                    @(context.PhoneNumber ?? "—")
                </MudText>

                <MudText Typo="Typo.caption"
                         Color="Color.Secondary">
                    @(context.Email ?? "—")
                </MudText>
            </MudTd>

            <MudTd DataLabel="Tài xế">
                <MudChip T="string"
                         Size="Size.Small"
                         Variant="Variant.Outlined"
                         Color="Color.Info">
                    @context.DriverCount tài xế
                </MudChip>
            </MudTd>

            <MudTd DataLabel="Trạng thái">
                <MudChip T="string"
                         Size="Size.Small"
                         Color="@(context.IsActive
                                                      ? Color.Success
                                                      : Color.Error)">
                    @(context.IsActive
                                    ? "Đang hoạt động"
                                    : "Ngừng hoạt động")
            </MudChip>
        </MudTd>

            <MudTd>
                <MudStack Row="true"
                          Spacing="1">

                    <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                   Color="Color.Primary"
                                   Href="@($"/admin/company-profiles/{context.Id}")" />

                @if (!context.IsDefault)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Star"
                                       Color="Color.Warning"
                                       Disabled="@_processing"
                                       OnClick="@(() => SetDefaultAsync(context.Id))" />

                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       Disabled="@_processing"
                                       OnClick="@(() => DeleteAsync(context))" />
                    }

                </MudStack>
            </MudTd>
        </RowTemplate>

        <NoRecordsContent>
            <MudText Class="pa-4">
                Không tìm thấy hồ sơ doanh nghiệp.
            </MudText>
        </NoRecordsContent>

        <PagerContent>
            <MudTablePager PageSizeOptions="@(new int[] { 10, 20, 50 })" />
        </PagerContent>
    </MudTable>
}

@code {
    private MudForm? _createForm;

    private bool _loading = true;
    private bool _creating;
    private bool _saving;
    private bool _processing;

    private string? _keyword;
    private bool? _activeFilter;

    private IReadOnlyList<CompanyProfileListItemDto> _items =
        Array.Empty<CompanyProfileListItemDto>();

    private CreateCompanyProfileRequest _createModel =
        CreateEmptyModel();

    private IEnumerable<CompanyProfileListItemDto> FilteredItems
    {
        get
        {
            var query = _items.AsEnumerable();

            if (_activeFilter.HasValue)
            {
                query = query.Where(
                    x => x.IsActive == _activeFilter.Value);
            }

            if (!string.IsNullOrWhiteSpace(_keyword))
            {
                var keyword = _keyword.Trim();

                query = query.Where(x =>
                    Contains(x.CompanyName, keyword) ||
                    Contains(x.TaxCode, keyword) ||
                    Contains(x.RepresentativeName, keyword) ||
                    Contains(x.PhoneNumber, keyword) ||
                    Contains(x.Email, keyword));
            }

            return query;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _loading = true;

            _items =
                await CompanyProfileService.GetListAsync(
                    new CompanyProfileFilter
                    {
                        Page = 1,
                        PageSize = 500
                    });
        }
        catch (Exception ex)
        {
            Snackbar.Add(
                ex.Message,
                Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void OpenCreate()
    {
        _createModel = CreateEmptyModel();
        _creating = true;
    }

    private void CloseCreate()
    {
        if (_saving)
            return;

        _creating = false;
        _createModel = CreateEmptyModel();
    }

    private async Task CreateAsync()
    {
        if (_saving || _createForm is null)
            return;

        await _createForm.ValidateAsync();

        if (!_createForm.IsValid)
            return;

        try
        {
            _saving = true;

            var authState =
                await AuthenticationStateProvider
                    .GetAuthenticationStateAsync();

            var userId =
                authState.User.FindFirst(
                    System.Security.Claims.ClaimTypes
                        .NameIdentifier)?.Value;

            if (string.IsNullOrWhiteSpace(userId))
            {
                Snackbar.Add(
                    "Không xác định được tài khoản quản trị.",
                    Severity.Error);

                return;
            }

            _createModel.ManagedByUserId = userId;

            var id =
                await CompanyProfileService.CreateAsync(
                    _createModel);

            Snackbar.Add(
                "Tạo hồ sơ doanh nghiệp thành công.",
                Severity.Success);

            _creating = false;

            Navigation.NavigateTo(
                $"/admin/company-profiles/{id}");
        }
        catch (Exception ex)
        {
            Snackbar.Add(
                ex.Message,
                Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task SetDefaultAsync(Guid id)
    {
        if (_processing)
            return;

        try
        {
            _processing = true;

            await CompanyProfileService.SetDefaultAsync(id);

            Snackbar.Add(
                "Đã cập nhật công ty mặc định.",
                Severity.Success);

            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _processing = false;
        }
    }

    private async Task DeleteAsync(
        CompanyProfileListItemDto company)
    {
        if (_processing)
            return;

        var confirmed =
            await JS.InvokeAsync<bool>(
                "confirm",
                $"Bạn có chắc muốn xóa công ty “{company.CompanyName}” không?");

        if (!confirmed)
            return;

        try
        {
            _processing = true;

            await CompanyProfileService.DeleteAsync(
                company.Id);

            Snackbar.Add(
                "Đã xóa hồ sơ doanh nghiệp.",
                Severity.Success);

            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _processing = false;
        }
    }

    private static CreateCompanyProfileRequest
        CreateEmptyModel()
    {
        return new CreateCompanyProfileRequest
        {
            IsActive = true
        };
    }

    private static bool Contains(
        string? value,
        string keyword)
    {
        return !string.IsNullOrWhiteSpace(value) &&
               value.Contains(
                   keyword,
                   StringComparison.OrdinalIgnoreCase);
    }
}