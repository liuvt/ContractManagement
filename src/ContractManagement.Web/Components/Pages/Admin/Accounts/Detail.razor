@page "/admin/accounts/{UserId}"
@attribute [Authorize(Roles = "Admin")]

@inject IAdminAccountService AdminAccountService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Chi tiết tài khoản</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-6">

    <MudStack Row="true"
              AlignItems="AlignItems.Center"
              Spacing="2"
              Class="mb-5">

        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                       Href="/admin/accounts"
                       Color="Color.Default" />

        <div>
            <MudText Typo="Typo.h4">
                Chi tiết tài khoản
            </MudText>

            <MudText Typo="Typo.body2"
                     Color="Color.Secondary">
                Cập nhật thông tin tài khoản và hồ sơ doanh nghiệp
            </MudText>
        </div>
    </MudStack>

    @if (_loading)
    {
        <MudPaper Elevation="1" Class="pa-6">
            <MudStack AlignItems="AlignItems.Center"
                      Spacing="3">

                <MudProgressCircular Indeterminate="true"
                                     Color="Color.Primary" />

                <MudText Color="Color.Secondary">
                    Đang tải thông tin tài khoản...
                </MudText>
            </MudStack>
        </MudPaper>
    }
    else if (_detail is null)
    {
        <MudAlert Severity="Severity.Error"
                  Variant="Variant.Outlined">
            Không tìm thấy tài khoản.
        </MudAlert>
    }
    else
    {
        <MudTabs Elevation="1"
                 Rounded="true"
                 PanelClass="pa-5">

            <MudTabPanel Text="Thông tin tài khoản"
                         Icon="@Icons.Material.Filled.Person">

                <MudForm @ref="_accountForm">
                    <MudGrid>
                        <MudItem xs="12">
                            <MudPaper Elevation="0"
                                      Outlined="true"
                                      Class="pa-4 mb-4">

                                <MudStack Row="true"
                                          AlignItems="AlignItems.Center"
                                          Spacing="3">

                                    <MudAvatar Color="Color.Primary"
                                               Size="Size.Large">
                                        <MudIcon Icon="@Icons.Material.Filled.ManageAccounts"
                                                 Size="Size.Large" />
                                    </MudAvatar>

                                    <div>
                                        <MudText Typo="Typo.h6">
                                            @_detail.FullName
                                        </MudText>

                                        <MudText Typo="Typo.body2"
                                                 Color="Color.Secondary">
                                            @_detail.UserName
                                        </MudText>
                                    </div>
                                </MudStack>
                            </MudPaper>
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudTextField T="string"
                                          Label="Tên đăng nhập"
                                          Value="@_detail.UserName"
                                          ReadOnly="true"
                                          Variant="Variant.Outlined"
                                          FullWidth="true" />
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudTextField T="string"
                                          Label="Mã nhân viên"
                                          @bind-Value="_accountModel.EmployeeCode"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          MaxLength="30" />
                        </MudItem>

                        <MudItem xs="12">
                            <MudTextField T="string"
                                          Label="Họ và tên"
                                          @bind-Value="_accountModel.FullName"
                                          Variant="Variant.Outlined"
                                          Required="true"
                                          RequiredError="Vui lòng nhập họ và tên."
                                          FullWidth="true"
                                          MaxLength="200" />
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudTextField T="string"
                                          Label="Số điện thoại"
                                          @bind-Value="_accountModel.PhoneNumber"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          MaxLength="20" />
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudTextField T="string"
                                          Label="Email"
                                          @bind-Value="_accountModel.Email"
                                          InputType="InputType.Email"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          MaxLength="256" />
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudSwitch T="bool"
                                       @bind-Value="_accountModel.IsActive"
                                       Color="Color.Success"
                                       Label="Tài khoản đang hoạt động" />
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudSwitch T="bool"
                                       @bind-Value="_accountModel.MustChangePassword"
                                       Color="Color.Warning"
                                       Label="Bắt buộc đổi mật khẩu" />
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudTextField T="string"
                                          Label="Ngày tạo"
                                          Value="@FormatDateTime(_detail.CreatedAt)"
                                          ReadOnly="true"
                                          Variant="Variant.Outlined"
                                          FullWidth="true" />
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudTextField T="string"
                                          Label="Cập nhật gần nhất"
                                          Value="@FormatDateTime(_detail.UpdatedAt)"
                                          ReadOnly="true"
                                          Variant="Variant.Outlined"
                                          FullWidth="true" />
                        </MudItem>
                    </MudGrid>

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Save"
                               Disabled="@_savingAccount"
                               OnClick="SaveAccountAsync"
                               Class="mt-5">

                        @if (_savingAccount)
                        {
                            <MudProgressCircular Indeterminate="true"
                                                 Size="Size.Small"
                                                 Class="mr-2" />
                        }

                        @(_savingAccount
                            ? "Đang lưu..."
                            : "Lưu thông tin tài khoản")
                    </MudButton>
                </MudForm>
            </MudTabPanel>

            <MudTabPanel Text="Hồ sơ doanh nghiệp"
                         Icon="@Icons.Material.Filled.Business">

                <MudStack Row="true"
                          Justify="Justify.SpaceBetween"
                          AlignItems="AlignItems.Center"
                          Class="company-list-header mb-4">

                    <div>
                        <MudText Typo="Typo.h6">
                            Danh sách hồ sơ doanh nghiệp
                        </MudText>

                        <MudText Typo="Typo.body2"
                                 Color="Color.Secondary">
                            Tài khoản đang quản lý @_companies.Count hồ sơ
                        </MudText>
                    </div>

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="OpenCreateCompany">
                        Thêm hồ sơ
                    </MudButton>
                </MudStack>

                @if (_companies.Count == 0)
                {
                    <MudAlert Severity="Severity.Info"
                              Variant="Variant.Outlined">
                        Tài khoản chưa có hồ sơ doanh nghiệp.
                    </MudAlert>
                }
                else
                {
                    <MudGrid>
                        @foreach (var company in _companies)
                        {
                            <MudItem xs="12" md="6">
                                <MudCard Elevation="1"
                                         Class="company-card">

                                    <MudCardContent>
                                        <MudStack Row="true"
                                                  Justify="Justify.SpaceBetween"
                                                  AlignItems="AlignItems.Start"
                                                  Spacing="2">

                                            <div class="company-title">
                                                <MudText Typo="Typo.h6">
                                                    @company.CompanyName
                                                </MudText>

                                                <MudText Typo="Typo.body2"
                                                         Color="Color.Secondary">
                                                    MST: @company.TaxCode
                                                </MudText>
                                            </div>

                                            <MudStack Spacing="1"
                                                      AlignItems="AlignItems.End">

                                                @if (company.IsDefault)
                                                {
                                                    <MudChip T="string"
                                                             Size="Size.Small"
                                                             Color="Color.Primary"
                                                             StartIcon="@Icons.Material.Filled.Star">
                                                        Mặc định
                                                    </MudChip>
                                                }

                                                <MudChip T="string"
                                                         Size="Size.Small"
                                                         Color="@(company.IsActive
                                                             ? Color.Success
                                                             : Color.Error)"
                                                         Variant="Variant.Outlined">
                                                    @(company.IsActive
                                                        ? "Hoạt động"
                                                        : "Ngừng hoạt động")
                                                </MudChip>
                                            </MudStack>
                                        </MudStack>

                                        <MudDivider Class="my-3" />

                                        <MudStack Spacing="1">
                                            <MudText Typo="Typo.body2">
                                                <b>Đại diện:</b>
                                                @company.RepresentativeName
                                            </MudText>

                                            <MudText Typo="Typo.body2">
                                                <b>Chức vụ:</b>
                                                @(company.RepresentativePosition
                                                    ?? "Chưa cập nhật")
                                            </MudText>

                                            <MudText Typo="Typo.body2">
                                                <b>CCCD:</b>
                                                @company.RepresentativeCitizenId
                                            </MudText>

                                            <MudText Typo="Typo.body2">
                                                <b>Điện thoại:</b>
                                                @(company.PhoneNumber
                                                    ?? "Chưa cập nhật")
                                            </MudText>

                                            <MudText Typo="Typo.body2">
                                                <b>Email:</b>
                                                @(company.Email
                                                    ?? "Chưa cập nhật")
                                            </MudText>

                                            <MudText Typo="Typo.body2">
                                                <b>Địa chỉ:</b>
                                                @company.Address
                                            </MudText>
                                        </MudStack>
                                    </MudCardContent>

                                    <MudCardActions>
                                        <MudButton Variant="Variant.Text"
                                                   Color="Color.Primary"
                                                   StartIcon="@Icons.Material.Filled.Edit"
                                                   OnClick="@(() => OpenEditCompany(company))">
                                            Cập nhật
                                        </MudButton>

                                        @if (!company.IsDefault)
                                        {
                                            <MudButton Variant="Variant.Text"
                                                       StartIcon="@Icons.Material.Filled.Star"
                                                       Disabled="@_processingCompany"
                                                       OnClick="@(() => SetDefaultAsync(company.Id))">
                                                Đặt mặc định
                                            </MudButton>
                                        }

                                        <MudSpacer />

                                        <MudTooltip Text="Xóa hồ sơ">
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                           Color="Color.Error"
                                                           Disabled="@_processingCompany"
                                                           OnClick="@(() => DeleteCompanyAsync(company))" />
                                        </MudTooltip>
                                    </MudCardActions>
                                </MudCard>
                            </MudItem>
                        }
                    </MudGrid>
                }
            </MudTabPanel>
        </MudTabs>
    }

    @if (_companyEditorVisible)
    {
        <div class="company-editor-overlay"
             role="dialog"
             aria-modal="true"
             aria-label="Hồ sơ doanh nghiệp">

            <MudPaper Class="company-editor-card pa-6"
                      Elevation="16">

                <MudStack Row="true"
                          Justify="Justify.SpaceBetween"
                          AlignItems="AlignItems.Center"
                          Class="mb-5">

                    <div>
                        <MudText Typo="Typo.h5">
                            @(_editingCompanyId.HasValue
                                ? "Cập nhật hồ sơ doanh nghiệp"
                                : "Thêm hồ sơ doanh nghiệp")
                        </MudText>

                        <MudText Typo="Typo.body2"
                                 Color="Color.Secondary">
                            Nhập đầy đủ thông tin pháp lý dùng để tạo hợp đồng
                        </MudText>
                    </div>

                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                   Disabled="@_savingCompany"
                                   OnClick="CloseCompanyEditor" />
                </MudStack>

                <MudForm @ref="_companyForm">
                    <MudGrid>
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle1"
                                     Class="mb-1">
                                Thông tin doanh nghiệp
                            </MudText>
                        </MudItem>

                        <MudItem xs="12">
                            <MudTextField T="string"
                                          Label="Tên doanh nghiệp"
                                          @bind-Value="_companyModel.CompanyName"
                                          Variant="Variant.Outlined"
                                          Required="true"
                                          RequiredError="Vui lòng nhập tên doanh nghiệp."
                                          FullWidth="true"
                                          MaxLength="300" />
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudTextField T="string"
                                          Label="Mã số thuế"
                                          @bind-Value="_companyModel.TaxCode"
                                          Variant="Variant.Outlined"
                                          Required="true"
                                          RequiredError="Vui lòng nhập mã số thuế."
                                          FullWidth="true"
                                          MaxLength="50" />
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudTextField T="string"
                                          Label="Số giấy phép kinh doanh"
                                          @bind-Value="_companyModel.BusinessLicenseNumber"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          MaxLength="100" />
                        </MudItem>

                        <MudItem xs="12">
                            <MudTextField T="string"
                                          Label="Địa chỉ"
                                          @bind-Value="_companyModel.Address"
                                          Variant="Variant.Outlined"
                                          Required="true"
                                          RequiredError="Vui lòng nhập địa chỉ."
                                          Lines="2"
                                          FullWidth="true"
                                          MaxLength="500" />
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudTextField T="string"
                                          Label="Số điện thoại"
                                          @bind-Value="_companyModel.PhoneNumber"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          MaxLength="20" />
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudTextField T="string"
                                          Label="Email"
                                          @bind-Value="_companyModel.Email"
                                          InputType="InputType.Email"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          MaxLength="256" />
                        </MudItem>

                        <MudItem xs="12">
                            <MudDivider Class="my-3" />

                            <MudText Typo="Typo.subtitle1"
                                     Class="mb-1">
                                Người đại diện
                            </MudText>
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudTextField T="string"
                                          Label="Họ tên người đại diện"
                                          @bind-Value="_companyModel.RepresentativeName"
                                          Variant="Variant.Outlined"
                                          Required="true"
                                          RequiredError="Vui lòng nhập người đại diện."
                                          FullWidth="true"
                                          MaxLength="200" />
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudTextField T="string"
                                          Label="Chức vụ"
                                          @bind-Value="_companyModel.RepresentativePosition"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          MaxLength="100" />
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudTextField T="string"
                                          Label="Số CCCD"
                                          @bind-Value="_companyModel.RepresentativeCitizenId"
                                          Variant="Variant.Outlined"
                                          Required="true"
                                          RequiredError="Vui lòng nhập số CCCD."
                                          FullWidth="true"
                                          MaxLength="20" />
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudDatePicker Label="Ngày cấp CCCD"
                                           @bind-Date="_companyModel.RepresentativeCitizenIdIssuedDate"
                                           DateFormat="dd/MM/yyyy"
                                           Variant="Variant.Outlined"
                                           FullWidth="true"
                                           Clearable="true" />
                        </MudItem>

                        <MudItem xs="12">
                            <MudTextField T="string"
                                          Label="Nơi cấp CCCD"
                                          @bind-Value="_companyModel.RepresentativeCitizenIdIssuedPlace"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          MaxLength="200" />
                        </MudItem>

                        <MudItem xs="12">
                            <MudDivider Class="my-3" />

                            <MudText Typo="Typo.subtitle1"
                                     Class="mb-1">
                                Thông tin thanh toán
                            </MudText>
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudTextField T="string"
                                          Label="Số tài khoản ngân hàng"
                                          @bind-Value="_companyModel.BankAccountNumber"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          MaxLength="50" />
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudTextField T="string"
                                          Label="Tên ngân hàng"
                                          @bind-Value="_companyModel.BankName"
                                          Variant="Variant.Outlined"
                                          FullWidth="true"
                                          MaxLength="200" />
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudSwitch T="bool"
                                       @bind-Value="_companyModel.IsActive"
                                       Label="Hồ sơ đang hoạt động"
                                       Color="Color.Success" />
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudSwitch T="bool"
                                       @bind-Value="_companyModel.IsDefault"
                                       Label="Hồ sơ mặc định"
                                       Color="Color.Primary" />
                        </MudItem>
                    </MudGrid>

                    <MudStack Row="true"
                              Justify="Justify.FlexEnd"
                              Spacing="2"
                              Class="mt-5">

                        <MudButton Variant="Variant.Text"
                                   Disabled="@_savingCompany"
                                   OnClick="CloseCompanyEditor">
                            Hủy
                        </MudButton>

                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Save"
                                   Disabled="@_savingCompany"
                                   OnClick="SaveCompanyAsync">

                            @if (_savingCompany)
                            {
                                <MudProgressCircular Indeterminate="true"
                                                     Size="Size.Small"
                                                     Class="mr-2" />
                            }

                            @(_savingCompany
                                ? "Đang lưu..."
                                : "Lưu hồ sơ")
                        </MudButton>
                    </MudStack>
                </MudForm>
            </MudPaper>
        </div>
    }

</MudContainer>

<style>
    .company-card {
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    .company-card .mud-card-content {
        flex: 1;
    }

    .company-title {
        min-width: 0;
    }

    .company-editor-overlay {
        position: fixed;
        inset: 0;
        z-index: 10000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 16px;
        background: rgba(15, 23, 42, 0.68);
        backdrop-filter: blur(4px);
        overscroll-behavior: contain;
    }

    .company-editor-card {
        width: min(100%, 900px);
        max-height: calc(100vh - 32px);
        overflow-y: auto;
        border-radius: 16px;
    }

    @@media (max-width: 600px) {
        .company-list-header {
            flex-direction: column;
            align-items: stretch !important;
            gap: 16px;
        }

        .company-editor-card {
            padding: 20px !important;
        }
    }
</style>

@code {
    [Parameter]
    public string UserId { get; set; } = string.Empty;

    private MudForm? _accountForm;
    private MudForm? _companyForm;

    private AdminAccountDetail? _detail;

    private readonly AccountEditorModel _accountModel = new();
    private readonly CompanyEditorModel _companyModel = new();
    private readonly List<CompanyProfileDto> _companies = [];

    private Guid? _editingCompanyId;

    private bool _loading = true;
    private bool _savingAccount;
    private bool _savingCompany;
    private bool _processingCompany;
    private bool _companyEditorVisible;

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        if (string.IsNullOrWhiteSpace(UserId))
        {
            _detail = null;
            _loading = false;
            return;
        }

        try
        {
            _loading = true;

            _detail =
                await AdminAccountService.GetDetailAsync(
                    UserId);

            if (_detail is null)
            {
                _companies.Clear();
                return;
            }

            MapDetailToAccountModel(_detail);

            _companies.Clear();
            _companies.AddRange(_detail.Companies);
        }
        catch (Exception ex)
        {
            _detail = null;
            _companies.Clear();

            Snackbar.Add(
                $"Không thể tải chi tiết tài khoản: {ex.Message}",
                Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SaveAccountAsync()
    {
        if (_savingAccount || _accountForm is null)
            return;

        await _accountForm.ValidateAsync();

        if (!_accountForm.IsValid)
            return;

        try
        {
            _savingAccount = true;

            var result =
                await AdminAccountService.UpdateAccountAsync(
                    new UpdateAdminAccountRequest
                    {
                        UserId = UserId,
                        FullName = _accountModel.FullName,
                        EmployeeCode = _accountModel.EmployeeCode,
                        PhoneNumber = _accountModel.PhoneNumber,
                        Email = _accountModel.Email,
                        IsActive = _accountModel.IsActive,
                        MustChangePassword =
                            _accountModel.MustChangePassword
                    });

            ShowResult(result);

            if (result.Succeeded)
                await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(
                $"Không thể cập nhật tài khoản: {ex.Message}",
                Severity.Error);
        }
        finally
        {
            _savingAccount = false;
        }
    }

    private void OpenCreateCompany()
    {
        _editingCompanyId = null;

        ResetCompanyModel();

        _companyModel.IsActive = true;
        _companyModel.IsDefault =
            _companies.Count == 0;

        _companyEditorVisible = true;
    }

    private void OpenEditCompany(
        CompanyProfileDto company)
    {
        _editingCompanyId = company.Id;

        _companyModel.CompanyName =
            company.CompanyName;

        _companyModel.TaxCode =
            company.TaxCode;

        _companyModel.BusinessLicenseNumber =
            company.BusinessLicenseNumber;

        _companyModel.Address =
            company.Address;

        _companyModel.PhoneNumber =
            company.PhoneNumber;

        _companyModel.Email =
            company.Email;

        _companyModel.RepresentativeName =
            company.RepresentativeName;

        _companyModel.RepresentativePosition =
            company.RepresentativePosition;

        _companyModel.RepresentativeCitizenId =
            company.RepresentativeCitizenId;

        _companyModel.RepresentativeCitizenIdIssuedDate =
            company.RepresentativeCitizenIdIssuedDate;

        _companyModel.RepresentativeCitizenIdIssuedPlace =
            company.RepresentativeCitizenIdIssuedPlace;

        _companyModel.BankAccountNumber =
            company.BankAccountNumber;

        _companyModel.BankName =
            company.BankName;

        _companyModel.IsActive =
            company.IsActive;

        _companyModel.IsDefault =
            company.IsDefault;

        _companyEditorVisible = true;
    }

    private void CloseCompanyEditor()
    {
        if (_savingCompany)
            return;

        _companyEditorVisible = false;
        _editingCompanyId = null;

        ResetCompanyModel();
    }

    private async Task SaveCompanyAsync()
    {
        if (_savingCompany || _companyForm is null)
            return;

        await _companyForm.ValidateAsync();

        if (!_companyForm.IsValid)
            return;

        try
        {
            _savingCompany = true;

            var result =
                await AdminAccountService
                    .SaveCompanyProfileAsync(
                        new SaveCompanyProfileRequest
                        {
                            Id = _editingCompanyId,
                            UserId = UserId,

                            CompanyName =
                                _companyModel.CompanyName,

                            TaxCode =
                                _companyModel.TaxCode,

                            BusinessLicenseNumber =
                                _companyModel.BusinessLicenseNumber,

                            Address =
                                _companyModel.Address,

                            PhoneNumber =
                                _companyModel.PhoneNumber,

                            Email =
                                _companyModel.Email,

                            RepresentativeName =
                                _companyModel.RepresentativeName,

                            RepresentativePosition =
                                _companyModel.RepresentativePosition,

                            RepresentativeCitizenId =
                                _companyModel.RepresentativeCitizenId,

                            RepresentativeCitizenIdIssuedDate =
                                _companyModel
                                    .RepresentativeCitizenIdIssuedDate,

                            RepresentativeCitizenIdIssuedPlace =
                                _companyModel
                                    .RepresentativeCitizenIdIssuedPlace,

                            BankAccountNumber =
                                _companyModel.BankAccountNumber,

                            BankName =
                                _companyModel.BankName,

                            IsActive =
                                _companyModel.IsActive,

                            IsDefault =
                                _companyModel.IsDefault
                        });

            ShowResult(result);

            if (!result.Succeeded)
                return;

            CloseCompanyEditor();

            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(
                $"Không thể lưu hồ sơ doanh nghiệp: {ex.Message}",
                Severity.Error);
        }
        finally
        {
            _savingCompany = false;
        }
    }

    private async Task SetDefaultAsync(
        Guid companyId)
    {
        if (_processingCompany)
            return;

        try
        {
            _processingCompany = true;

            var result =
                await AdminAccountService
                    .SetDefaultCompanyAsync(
                        UserId,
                        companyId);

            ShowResult(result);

            if (result.Succeeded)
                await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(
                $"Không thể cập nhật hồ sơ mặc định: {ex.Message}",
                Severity.Error);
        }
        finally
        {
            _processingCompany = false;
        }
    }

    private async Task DeleteCompanyAsync(
        CompanyProfileDto company)
    {
        if (_processingCompany)
            return;

        var confirmed =
            await DialogService.ShowMessageBox(
                "Xóa hồ sơ doanh nghiệp",
                $"Bạn có chắc muốn xóa hồ sơ “{company.CompanyName}” không?",
                yesText: "Xóa",
                cancelText: "Hủy");

        if (confirmed != true)
            return;

        try
        {
            _processingCompany = true;

            var result =
                await AdminAccountService
                    .DeleteCompanyProfileAsync(
                        UserId,
                        company.Id);

            ShowResult(result);

            if (result.Succeeded)
                await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(
                $"Không thể xóa hồ sơ doanh nghiệp: {ex.Message}",
                Severity.Error);
        }
        finally
        {
            _processingCompany = false;
        }
    }

    private void MapDetailToAccountModel(
        AdminAccountDetail detail)
    {
        _accountModel.FullName =
            detail.FullName;

        _accountModel.EmployeeCode =
            detail.EmployeeCode;

        _accountModel.PhoneNumber =
            detail.PhoneNumber;

        _accountModel.Email =
            detail.Email;

        _accountModel.IsActive =
            detail.IsActive;

        _accountModel.MustChangePassword =
            detail.MustChangePassword;
    }

    private void ResetCompanyModel()
    {
        _companyModel.CompanyName =
            string.Empty;

        _companyModel.TaxCode =
            string.Empty;

        _companyModel.BusinessLicenseNumber =
            null;

        _companyModel.Address =
            string.Empty;

        _companyModel.PhoneNumber =
            null;

        _companyModel.Email =
            null;

        _companyModel.RepresentativeName =
            string.Empty;

        _companyModel.RepresentativePosition =
            null;

        _companyModel.RepresentativeCitizenId =
            string.Empty;

        _companyModel.RepresentativeCitizenIdIssuedDate =
            null;

        _companyModel.RepresentativeCitizenIdIssuedPlace =
            null;

        _companyModel.BankAccountNumber =
            null;

        _companyModel.BankName =
            null;

        _companyModel.IsActive =
            true;

        _companyModel.IsDefault =
            false;
    }

    private void ShowResult(
        ServiceResult result)
    {
        if (result.Succeeded)
        {
            Snackbar.Add(
                result.Message ?? "Thao tác thành công.",
                Severity.Success);

            return;
        }

        if (result.Errors.Count == 0)
        {
            Snackbar.Add(
                result.Message ?? "Thao tác không thành công.",
                Severity.Error);

            return;
        }

        foreach (var error in result.Errors)
        {
            Snackbar.Add(
                error,
                Severity.Error);
        }
    }

    private static string FormatDateTime(
        DateTime? value)
    {
        return value.HasValue
            ? value.Value.ToLocalTime()
                .ToString("dd/MM/yyyy HH:mm")
            : "Chưa cập nhật";
    }

