@page "/admin/accounts"
@attribute [Authorize(Roles = "Admin")]

@inject IAdminAccountService AdminAccountService
@inject ISnackbar Snackbar

<PageTitle>Quản lý tài khoản</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="py-6">

    <MudStack Row="true"
              Justify="Justify.SpaceBetween"
              AlignItems="AlignItems.Center"
              Class="admin-account-header mb-5">

        <div>
            <MudText Typo="Typo.h4">
                Quản lý tài khoản
            </MudText>

            <MudText Typo="Typo.body2"
                     Color="Color.Secondary">
                Quản lý tài khoản và hồ sơ doanh nghiệp
            </MudText>
        </div>

        <MudTextField T="string"
                      @bind-Value="_searchText"
                      Placeholder="Tìm tên, tài khoản, mã nhân viên..."
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true"
                      Clearable="true"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Class="admin-account-search" />
    </MudStack>

    @if (_loading)
    {
        <MudPaper Elevation="1" Class="pa-6">
            <MudStack AlignItems="AlignItems.Center"
                      Spacing="3">

                <MudProgressCircular Indeterminate="true"
                                     Color="Color.Primary" />

                <MudText Color="Color.Secondary">
                    Đang tải danh sách tài khoản...
                </MudText>
            </MudStack>
        </MudPaper>
    }
    else if (_items.Count == 0)
    {
        <MudAlert Severity="Severity.Info"
                  Variant="Variant.Outlined">
            Chưa có tài khoản nào trong hệ thống.
        </MudAlert>
    }
    else
    {
        <MudTable T="AdminAccountListItem"
                  Items="@FilteredItems"
                  Hover="true"
                  Striped="true"
                  Breakpoint="Breakpoint.Sm"
                  Elevation="1"
                  RowsPerPage="10">

            <HeaderContent>
                <MudTh>Tài khoản</MudTh>
                <MudTh>Họ và tên</MudTh>
                <MudTh>Mã nhân viên</MudTh>
                <MudTh>Số điện thoại</MudTh>
                <MudTh>Email</MudTh>
                <MudTh>Hồ sơ doanh nghiệp</MudTh>
                <MudTh>Trạng thái</MudTh>
                <MudTh Style="width:90px;"></MudTh>
            </HeaderContent>

            <RowTemplate>
                <MudTd DataLabel="Tài khoản">
                    <MudStack Row="true"
                              AlignItems="AlignItems.Center"
                              Spacing="2">

                        <MudAvatar Color="Color.Primary"
                                   Size="Size.Small">
                            <MudIcon Icon="@Icons.Material.Filled.Person"
                                     Size="Size.Small" />
                        </MudAvatar>

                        <MudText Typo="Typo.subtitle2">
                            @context.UserName
                        </MudText>
                    </MudStack>
                </MudTd>

                <MudTd DataLabel="Họ và tên">
                    @context.FullName
                </MudTd>

                <MudTd DataLabel="Mã nhân viên">
                    @(context.EmployeeCode ?? "—")
                </MudTd>

                <MudTd DataLabel="Số điện thoại">
                    @(context.PhoneNumber ?? "—")
                </MudTd>

                <MudTd DataLabel="Email">
                    @(context.Email ?? "—")
                </MudTd>

                <MudTd DataLabel="Hồ sơ doanh nghiệp">
                    <MudChip T="string"
                             Size="Size.Small"
                             Color="Color.Info"
                             Variant="Variant.Outlined">
                        @context.CompanyCount hồ sơ
                    </MudChip>
                </MudTd>

                <MudTd DataLabel="Trạng thái">
                    <MudStack Spacing="1">
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Color="@(context.IsActive
                                                                      ? Color.Success
                                                                      : Color.Error)">
                            @(context.IsActive
                                                    ? "Hoạt động"
                                                    : "Ngừng hoạt động")
                    </MudChip>

                    @if (context.MustChangePassword)
                        {
                            <MudChip T="string"
                                     Size="Size.Small"
                                     Color="Color.Warning"
                                     Variant="Variant.Outlined">
                                Yêu cầu đổi mật khẩu
                            </MudChip>
                        }
                    </MudStack>
                </MudTd>

                <MudTd>
                    <MudTooltip Text="Xem và cập nhật">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Primary"
                                       Href="@($"/admin/accounts/{context.Id}")" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>

            <NoRecordsContent>
                <MudText Class="pa-4"
                         Color="Color.Secondary">
                    Không tìm thấy tài khoản phù hợp.
                </MudText>
            </NoRecordsContent>

            <PagerContent>
                <MudTablePager PageSizeOptions="@(new int[] { 10, 20, 50 })"
                               RowsPerPageString="Số dòng"
                               InfoFormat="{first_item}-{last_item} / {all_items}" />
            </PagerContent>
        </MudTable>
    }

</MudContainer>

<style>
    .admin-account-search {
        width: 360px;
        max-width: 100%;
    }

    @@media (max-width: 600px) {
        .admin-account-header {
            flex-direction: column;
            align-items: stretch !important;
            gap: 16px;
        }

        .admin-account-search {
            width: 100%;
        }
    }
</style>

@code {
    private bool _loading = true;
    private string? _searchText;

    private IReadOnlyList<AdminAccountListItem> _items =
        Array.Empty<AdminAccountListItem>();

    private IEnumerable<AdminAccountListItem> FilteredItems
    {
        get
        {
            if (string.IsNullOrWhiteSpace(_searchText))
                return _items;

            var keyword = _searchText.Trim();

            return _items.Where(item =>
                Contains(item.UserName, keyword) ||
                Contains(item.FullName, keyword) ||
                Contains(item.EmployeeCode, keyword) ||
                Contains(item.PhoneNumber, keyword) ||
                Contains(item.Email, keyword));
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _loading = true;

            _items =
                await AdminAccountService.GetAccountsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(
                $"Không thể tải danh sách tài khoản: {ex.Message}",
                Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private static bool Contains(
        string? value,
        string keyword)
    {
        return !string.IsNullOrWhiteSpace(value) &&
               value.Contains(
                   keyword,
                   StringComparison.OrdinalIgnoreCase);
    }
}