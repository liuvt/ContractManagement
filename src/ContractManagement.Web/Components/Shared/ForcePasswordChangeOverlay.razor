@implements IDisposable
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

@if (_visible)
{
    <div class="forced-password-overlay" role="dialog" aria-modal="true" aria-labelledby="forced-password-title">
        <MudPaper Class="forced-password-card pa-6" Elevation="16">
            @if (_loading)
            {
                <MudStack AlignItems="AlignItems.Center" Spacing="3">
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                    <MudText>Đang kiểm tra tài khoản...</MudText>
                </MudStack>
            }
            else
            {
                <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="mb-5">
                    <MudIcon Icon="@Icons.Material.Filled.LockReset" Size="Size.Large" Color="Color.Primary" />
                    <MudText Id="forced-password-title" Typo="Typo.h5" Align="Align.Center">
                        Cập nhật mật khẩu
                    </MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                        Tài khoản của bạn đang được yêu cầu tạo mật khẩu mới trước khi tiếp tục sử dụng hệ thống.
                    </MudText>
                </MudStack>

                <MudForm @ref="_form">
                    <MudTextField T="string"
                                  Label="Mật khẩu mới"
                                  @bind-Value="_model.NewPassword"
                                  InputType="@(_showNewPassword ? InputType.Text : InputType.Password)"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  RequiredError="Vui lòng nhập mật khẩu mới."
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@(_showNewPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                  OnAdornmentClick="@(() => _showNewPassword = !_showNewPassword)"
                                  FullWidth="true"
                                  Class="mb-4" />

                    <MudTextField T="string"
                                  Label="Nhập lại mật khẩu mới"
                                  @bind-Value="_model.ConfirmPassword"
                                  InputType="@(_showConfirmPassword ? InputType.Text : InputType.Password)"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  RequiredError="Vui lòng nhập lại mật khẩu mới."
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@(_showConfirmPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                  OnAdornmentClick="@(() => _showConfirmPassword = !_showConfirmPassword)"
                                  FullWidth="true"
                                  Class="mb-4" />

                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
                        Mật khẩu tối thiểu 6 ký tự và phải có ít nhất một chữ số.
                    </MudAlert>

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               Size="Size.Large"
                               Disabled="@_saving"
                               StartIcon="@Icons.Material.Filled.Save"
                               OnClick="SaveAsync">
                        @if (_saving)
                        {
                            <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-2" />
                        }
                        @(_saving ? "Đang cập nhật..." : "Cập nhật mật khẩu")
                    </MudButton>
                </MudForm>

                <form method="post" action="/account/logout/submit" class="mt-3 forced-password-logout">
                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Text"
                               Color="Color.Secondary"
                               FullWidth="true"
                               Disabled="@_saving"
                               StartIcon="@Icons.Material.Filled.Logout">
                        Đăng xuất
                    </MudButton>
                </form>
            }
        </MudPaper>
    </div>
}

<style>
    .forced-password-overlay {
        position: fixed;
        inset: 0;
        z-index: 10000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 16px;
        background: rgba(15, 23, 42, 0.72);
        backdrop-filter: blur(5px);
        overscroll-behavior: contain;
    }

    .forced-password-card {
        width: min(100%, 480px);
        max-height: calc(100vh - 32px);
        overflow-y: auto;
        border-radius: 16px;
    }

    .forced-password-logout {
        width: 100%;
    }
</style>

@code {
    private MudForm? _form;
    private ApplicationUser? _user;
    private bool _visible;
    private bool _loading;
    private bool _saving;
    private bool _showNewPassword;
    private bool _showConfirmPassword;
    private readonly PasswordModel _model = new();

    protected override async Task OnInitializedAsync()
    {
        Navigation.LocationChanged += OnLocationChanged;
        await CheckRequiredAsync();
    }

    private async void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        try
        {
            await InvokeAsync(CheckRequiredAsync);
        }
        catch
        {
            // Không làm gián đoạn điều hướng; lần render kế tiếp sẽ kiểm tra lại.
        }
    }

    private async Task CheckRequiredAsync()
    {
        if (_saving)
            return;

        _loading = true;

        try
        {
            var state = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var principal = state.User;

            if (principal.Identity?.IsAuthenticated != true)
            {
                _user = null;
                _visible = false;
                return;
            }

            _user = await UserManager.GetUserAsync(principal);
            _visible = _user?.IsActive == true && _user.MustChangePassword;
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task SaveAsync()
    {
        if (_saving || _form is null || _user is null)
            return;

        await _form.ValidateAsync();

        if (!_form.IsValid)
            return;

        if (!string.Equals(_model.NewPassword, _model.ConfirmPassword, StringComparison.Ordinal))
        {
            Snackbar.Add("Mật khẩu nhập lại không khớp.", Severity.Warning);
            return;
        }

        try
        {
            _saving = true;

            var token = await UserManager.GeneratePasswordResetTokenAsync(_user);
            var resetResult = await UserManager.ResetPasswordAsync(_user, token, _model.NewPassword);

            if (!resetResult.Succeeded)
            {
                ShowErrors(resetResult.Errors);
                return;
            }

            _user.MustChangePassword = false;
            _user.UpdatedAt = DateTime.UtcNow;

            var updateResult = await UserManager.UpdateAsync(_user);

            if (!updateResult.Succeeded)
            {
                // Không cho mở hệ thống nếu chưa lưu được trạng thái bắt buộc đổi mật khẩu.
                ShowErrors(updateResult.Errors);
                return;
            }

            _model.NewPassword = string.Empty;
            _model.ConfirmPassword = string.Empty;
            _visible = false;

            Snackbar.Add("Cập nhật mật khẩu thành công. Vui lòng đăng nhập lại.", Severity.Success);

            var loginUrl = "/account/login?passwordChanged=true";
            var logoutUrl = "/account/logout?returnUrl=" + Uri.EscapeDataString(loginUrl);
            Navigation.NavigateTo(logoutUrl, forceLoad: true, replace: true);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private void ShowErrors(IEnumerable<IdentityError> errors)
    {
        foreach (var error in errors)
            Snackbar.Add(TranslateIdentityError(error), Severity.Error);
    }

    private static string TranslateIdentityError(IdentityError error) => error.Code switch
    {
        "PasswordTooShort" => "Mật khẩu mới chưa đủ độ dài.",
        "PasswordRequiresDigit" => "Mật khẩu phải có ít nhất một chữ số.",
        "PasswordRequiresLower" => "Mật khẩu phải có ít nhất một chữ thường.",
        "PasswordRequiresUpper" => "Mật khẩu phải có ít nhất một chữ hoa.",
        "PasswordRequiresNonAlphanumeric" => "Mật khẩu phải có ít nhất một ký tự đặc biệt.",
        "PasswordRequiresUniqueChars" => "Mật khẩu chưa đủ số ký tự khác nhau.",
        _ => error.Description
    };

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private sealed class PasswordModel
    {
        public string NewPassword { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
