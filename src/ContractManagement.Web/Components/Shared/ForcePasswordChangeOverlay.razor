@implements IDisposable

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

@if (_visible)
{
    <div class="forced-password-overlay"
         role="dialog"
         aria-modal="true"
         aria-labelledby="forced-password-title">

        <MudPaper Class="forced-password-card pa-6"
                  Elevation="16">

            @if (_loading)
            {
                <MudStack AlignItems="AlignItems.Center"
                          Spacing="3">

                    <MudProgressCircular Indeterminate="true"
                                         Color="Color.Primary" />

                    <MudText>
                        Đang kiểm tra tài khoản...
                    </MudText>
                </MudStack>
            }
            else
            {
                <MudStack AlignItems="AlignItems.Center"
                          Spacing="2"
                          Class="mb-5">

                    <MudIcon Icon="@Icons.Material.Filled.LockReset"
                             Size="Size.Large"
                             Color="Color.Primary" />

                    <MudText Id="forced-password-title"
                             Typo="Typo.h5"
                             Align="Align.Center">

                        @(_manualChange
                                        ? "Đổi mật khẩu"
                                        : "Cập nhật mật khẩu bắt buộc")
            </MudText>

                    <MudText Typo="Typo.body2"
                             Color="Color.Secondary"
                             Align="Align.Center">

                @if (_manualChange)
                        {
                            <span>
                                Vui lòng nhập mật khẩu mới cho tài khoản của bạn.
                            </span>
                        }
                        else
                        {
                            <span>
                                Tài khoản của bạn đang được yêu cầu tạo mật khẩu mới
                                trước khi tiếp tục sử dụng hệ thống.
                            </span>
                        }
                    </MudText>
                </MudStack>

                <MudForm @ref="_form">
                    <MudTextField T="string"
                                  Label="Mật khẩu mới"
                                  @bind-Value="_model.NewPassword"
                                  InputType="@(_showNewPassword
                                                                        ? InputType.Text
                                                                        : InputType.Password)"
                                                                                             Variant="Variant.Outlined"
                                                                                             Required="true"
                                                                                             RequiredError="Vui lòng nhập mật khẩu mới."
                                                                                             Adornment="Adornment.End"
                                                                                             AdornmentIcon="@(_showNewPassword
                                                                ? Icons.Material.Filled.VisibilityOff
                                                                : Icons.Material.Filled.Visibility)"
                                                                                                   OnAdornmentClick="ToggleNewPasswordVisibility"
                                                                                                   FullWidth="true"
                                                                                                   Class="mb-4" />

            <MudTextField T="string"
                          Label="Nhập lại mật khẩu mới"
                          @bind-Value="_model.ConfirmPassword"
                          InputType="@(_showConfirmPassword
                                                                ? InputType.Text
                                                                : InputType.Password)"
                                                                                     Variant="Variant.Outlined"
                                                                                     Required="true"
                                                                                     RequiredError="Vui lòng nhập lại mật khẩu mới."
                                                                                     Adornment="Adornment.End"
                                                                                     AdornmentIcon="@(_showConfirmPassword
                                                                ? Icons.Material.Filled.VisibilityOff
                                                                : Icons.Material.Filled.Visibility)"
                          OnAdornmentClick="ToggleConfirmPasswordVisibility"
                          FullWidth="true"
                          Class="mb-4" />

                    <MudAlert Severity="Severity.Info"
                              Variant="Variant.Outlined"
                              Class="mb-4">
                        Mật khẩu tối thiểu 6 ký tự và phải có ít nhất một chữ số.
                    </MudAlert>

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               Size="Size.Large"
                               Disabled="@_saving"
                               StartIcon="@Icons.Material.Filled.Save"
                               OnClick="SaveAsync">

                @if (_saving)
                        {
                            <MudProgressCircular Indeterminate="true"
                                                 Size="Size.Small"
                                                 Class="mr-2" />
                        }

                @(_saving
                            ? "Đang cập nhật..."
                            : "Cập nhật mật khẩu")
            </MudButton>
        </MudForm>

        @if (_manualChange)
                {
                    <MudButton Variant="Variant.Text"
                               Color="Color.Secondary"
                               FullWidth="true"
                               Disabled="@_saving"
                               StartIcon="@Icons.Material.Filled.Close"
                               Class="mt-3"
                               OnClick="Close">
                        Đóng
                    </MudButton>
                }
                else
                {
                    <form method="post"
                          action="/account/logout/submit"
                          class="forced-password-logout mt-3">

                        <AntiforgeryToken />

                        <MudButton ButtonType="ButtonType.Submit"
                                   Variant="Variant.Text"
                                   Color="Color.Secondary"
                                   FullWidth="true"
                                   Disabled="@_saving"
                                   StartIcon="@Icons.Material.Filled.Logout">
                            Đăng xuất
                        </MudButton>
                    </form>
                }
            }
        </MudPaper>
    </div>
}

<style>
    .forced-password-overlay {
        position: fixed;
        inset: 0;
        z-index: 10000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 16px;
        background: rgba(15, 23, 42, 0.72);
        backdrop-filter: blur(5px);
        overscroll-behavior: contain;
    }

    .forced-password-card {
        width: min(100%, 480px);
        max-height: calc(100vh - 32px);
        overflow-y: auto;
        border-radius: 16px;
    }

    .forced-password-logout {
        width: 100%;
    }
</style>

@code {
    private MudForm? _form;
    private ApplicationUser? _user;

    private bool _visible;
    private bool _loading;
    private bool _saving;
    private bool _manualChange;
    private bool _showNewPassword;
    private bool _showConfirmPassword;

    private readonly PasswordModel _model = new();

    protected override async Task OnInitializedAsync()
    {
        Navigation.LocationChanged += OnLocationChanged;

        await CheckRequiredAsync();
    }

    private async void OnLocationChanged(
        object? sender,
        Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        try
        {
            await InvokeAsync(CheckRequiredAsync);
        }
        catch
        {
            // Không làm gián đoạn quá trình điều hướng.
        }
    }

    /// <summary>
    /// Gọi từ UserMenu khi người dùng chủ động chọn đổi mật khẩu.
    /// </summary>
    public async Task ShowAsync()
    {
        if (_saving)
            return;

        _loading = true;
        _visible = true;

        ResetForm();

        try
        {
            var state =
                await AuthenticationStateProvider
                    .GetAuthenticationStateAsync();

            var principal = state.User;

            if (principal.Identity?.IsAuthenticated != true)
            {
                ResetOverlayState();
                return;
            }

            _user = await UserManager.GetUserAsync(principal);

            if (_user is null)
            {
                ResetOverlayState();

                Snackbar.Add(
                    "Không tìm thấy thông tin tài khoản.",
                    Severity.Error);

                return;
            }

            if (!_user.IsActive)
            {
                ResetOverlayState();

                Snackbar.Add(
                    "Tài khoản đã bị vô hiệu hóa.",
                    Severity.Error);

                return;
            }

            /*
             * Nếu tài khoản đang bị bắt buộc đổi mật khẩu,
             * dù được gọi từ menu vẫn không cho phép đóng overlay.
             */
            _manualChange = !_user.MustChangePassword;
            _visible = true;
        }
        catch (Exception ex)
        {
            ResetOverlayState();

            Snackbar.Add(
                $"Không thể mở chức năng đổi mật khẩu: {ex.Message}",
                Severity.Error);
        }
        finally
        {
            _loading = false;

            await InvokeAsync(StateHasChanged);
        }
    }

    /// <summary>
    /// Kiểm tra tài khoản có đang bị bắt buộc đổi mật khẩu không.
    /// </summary>
    private async Task CheckRequiredAsync()
    {
        /*
         * Khi người dùng đang chủ động đổi mật khẩu,
         * không để sự kiện điều hướng đóng hoặc đổi trạng thái overlay.
         */
        if (_saving || _manualChange)
            return;

        _loading = true;

        try
        {
            var state =
                await AuthenticationStateProvider
                    .GetAuthenticationStateAsync();

            var principal = state.User;

            if (principal.Identity?.IsAuthenticated != true)
            {
                ResetOverlayState();
                return;
            }

            _user = await UserManager.GetUserAsync(principal);

            if (_user is null || !_user.IsActive)
            {
                ResetOverlayState();
                return;
            }

            _manualChange = false;
            _visible = _user.MustChangePassword;

            if (_visible)
                ResetForm();
        }
        catch
        {
            /*
             * Khi việc kiểm tra thất bại, không tự ý mở hệ thống
             * nếu overlay bắt buộc đang hiển thị.
             */
        }
        finally
        {
            _loading = false;

            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task SaveAsync()
    {
        if (_saving || _form is null || _user is null)
            return;

        await _form.ValidateAsync();

        if (!_form.IsValid)
            return;

        if (!string.Equals(
                _model.NewPassword,
                _model.ConfirmPassword,
                StringComparison.Ordinal))
        {
            Snackbar.Add(
                "Mật khẩu nhập lại không khớp.",
                Severity.Warning);

            return;
        }

        try
        {
            _saving = true;

            /*
             * Tạo token reset vì trường hợp bắt buộc đổi mật khẩu
             * không yêu cầu nhập lại mật khẩu cũ.
             */
            var token =
                await UserManager.GeneratePasswordResetTokenAsync(_user);

            var resetResult =
                await UserManager.ResetPasswordAsync(
                    _user,
                    token,
                    _model.NewPassword);

            if (!resetResult.Succeeded)
            {
                ShowErrors(resetResult.Errors);
                return;
            }

            _user.MustChangePassword = false;
            _user.UpdatedAt = DateTime.UtcNow;

            var updateResult =
                await UserManager.UpdateAsync(_user);

            if (!updateResult.Succeeded)
            {
                /*
                 * Mật khẩu đã đổi nhưng trạng thái bắt buộc chưa lưu được.
                 * Không đóng overlay để tránh cho phép truy cập hệ thống.
                 */
                ShowErrors(updateResult.Errors);
                return;
            }

            ResetForm();

            _manualChange = false;
            _visible = false;

            Snackbar.Add(
                "Cập nhật mật khẩu thành công. Vui lòng đăng nhập lại.",
                Severity.Success);

            var loginUrl =
                "/account/login?passwordChanged=true";

            var logoutUrl =
                "/account/logout?returnUrl=" +
                Uri.EscapeDataString(loginUrl);

            Navigation.NavigateTo(
                logoutUrl,
                forceLoad: true,
                replace: true);
        }
        catch (Exception ex)
        {
            Snackbar.Add(
                $"Không thể cập nhật mật khẩu: {ex.Message}",
                Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private void Close()
    {
        if (_saving || !_manualChange)
            return;

        ResetForm();

        _manualChange = false;
        _visible = false;
        _user = null;
    }

    private void ToggleNewPasswordVisibility()
    {
        _showNewPassword = !_showNewPassword;
    }

    private void ToggleConfirmPasswordVisibility()
    {
        _showConfirmPassword = !_showConfirmPassword;
    }

    private async Task ResetForm()
    {
        _model.NewPassword = string.Empty;
        _model.ConfirmPassword = string.Empty;

        _showNewPassword = false;
        _showConfirmPassword = false;
    }

    private void ResetOverlayState()
    {
        ResetForm();

        _user = null;
        _visible = false;
        _manualChange = false;
    }

    private void ShowErrors(
        IEnumerable<IdentityError> errors)
    {
        foreach (var error in errors)
        {
            Snackbar.Add(
                TranslateIdentityError(error),
                Severity.Error);
        }
    }

    private static string TranslateIdentityError(
        IdentityError error)
    {
        return error.Code switch
        {
            "PasswordTooShort"
                => "Mật khẩu mới chưa đủ độ dài.",

            "PasswordRequiresDigit"
                => "Mật khẩu phải có ít nhất một chữ số.",

            "PasswordRequiresLower"
                => "Mật khẩu phải có ít nhất một chữ thường.",

            "PasswordRequiresUpper"
                => "Mật khẩu phải có ít nhất một chữ hoa.",

            "PasswordRequiresNonAlphanumeric"
                => "Mật khẩu phải có ít nhất một ký tự đặc biệt.",

            "PasswordRequiresUniqueChars"
                => "Mật khẩu chưa đủ số ký tự khác nhau.",

            "InvalidToken"
                => "Phiên đổi mật khẩu không hợp lệ. Vui lòng thử lại.",

            _ => error.Description
        };
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private sealed class PasswordModel
    {
        public string NewPassword { get; set; } = string.Empty;

        public string ConfirmPassword { get; set; } = string.Empty;
    }
}