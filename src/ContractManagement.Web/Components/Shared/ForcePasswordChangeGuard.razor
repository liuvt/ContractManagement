@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation

@code {
    private bool _checking;

    protected override async Task OnParametersSetAsync()
    {
        await CheckAsync();
    }

    private async Task CheckAsync()
    {
        if (_checking)
            return;

        try
        {
            _checking = true;

            var relativeUrl =
                Navigation.ToBaseRelativePath(
                    Navigation.Uri);

            if (IsAllowedPath(relativeUrl))
                return;

            var authenticationState =
                await AuthenticationStateProvider
                    .GetAuthenticationStateAsync();

            var principal =
                authenticationState.User;

            if (principal.Identity?.IsAuthenticated != true)
                return;

            var user =
                await UserManager.GetUserAsync(principal);

            if (user?.MustChangePassword == true)
            {
                Navigation.NavigateTo(
                    "/account/change-password",
                    forceLoad: true);
            }
        }
        finally
        {
            _checking = false;
        }
    }

    private static bool IsAllowedPath(
        string relativeUrl)
    {
        var path = relativeUrl
            .Split('?', '#')[0]
            .Trim('/')
            .ToLowerInvariant();

        return path == "account/change-password"
            || path == "account/logout"
            || path == "account/login"
            || path.StartsWith(
                "_framework",
                StringComparison.OrdinalIgnoreCase);
    }
}